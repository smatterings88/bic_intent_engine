  "migrationRisks": [
    {
      "risk": "TanStack Router/Start APIs throughout",
      "where": ["src/routes", "src/router.tsx", "src/components/SiteLayout.tsx"],
      "recommendedFix": "Map to Next App Router pages/layouts/metadata; remove routeTree.gen dependency"
    },
    {
      "risk": "import.meta.env in error component",
      "where": ["src/router.tsx"],
      "recommendedFix": "Use NODE_ENV or Next-supported env pattern in error boundary"
    },
    {
      "risk": "Cloudflare worker build path (wrangler + dual dist)",
      "where": ["wrangler.jsonc", "package.json", "vite toolchain"],
      "recommendedFix": "Vercel uses next build; separate Cloudflare artifacts from Next deploy"
    },
    {
      "risk": "Hardcoded external social preview image URLs",
      "where": ["src/routes/__root.tsx"],
      "recommendedFix": "Self-host OG image; set metadataBase in Next"
    },
    {
      "risk": "Fonts loaded via external stylesheet links",
      "where": ["src/routes/__root.tsx"],
      "recommendedFix": "next/font/google for Inter and Source Serif 4"
    },
    {
      "risk": "window/document in hooks and some UI",
      "where": ["src/hooks/use-mobile.tsx", "src/components/ui/sidebar.tsx"],
      "recommendedFix": "use client boundaries; avoid importing client modules into server layouts"
    },
    {
      "risk": "Contact form has no server integration",
      "where": ["src/routes/contact.tsx"],
      "recommendedFix": "Phase 2+ Server Action or API route + GHL as per product plan"
    },
    {
      "risk": "Future root dynamic [slug] may shadow static routes",
      "where": ["planned Next structure"],
      "recommendedFix": "Route groups, explicit static segments, or middleware slug allowlist"
    }
  ],
