# Copy to `.env.local` for local development (never commit secrets).
# On Vercel, set the same variables in Project → Settings → Environment Variables.

# ── Public site ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://businessimpactcanada.com

# Google Tag Manager (optional; defaults to GTM-KQHFRMK8 when unset)
NEXT_PUBLIC_GTM_ID=GTM-KQHFRMK8

# Post–opt-in CTAs (optional public URLs for landing-page thank-you links)
NEXT_PUBLIC_SHERPA_DEMO_URL=
NEXT_PUBLIC_WEBINAR_URL=
NEXT_PUBLIC_SHERPA_OFFER_URL=

# ── Firebase — client (required for /app login and admin UI) ─────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: App Check site key (reserved — not wired yet)
NEXT_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY=

# ── Firebase — server (required for admin APIs, Firestore, profile sync) ─────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the service-account private key as one line; use \n for line breaks.
# env.ts converts \\n → real newlines before firebase-admin uses the key.
FIREBASE_PRIVATE_KEY=

# ── ZenithMind ingestion (server-only; min 16 characters) ────────────────────
ZENITH_INGEST_SECRET=

# Zenith Content v1.2 HTTP ingestion (optional; falls back to ZENITH_INGEST_SECRET)
ZENITH_CONTENT_SECRET=

# ── GoHighLevel — Private Integration (required for lead sync / form submit) ─
# Create: GHL → Settings → Other Settings → Private Integrations → Create New Integration
# Copy token once (pit-…). Minimum scopes: View Contacts, Edit Contacts, View Locations
GHL_PIT_TOKEN=
GHL_LOCATION_ID=

# LeadConnector v2 defaults (override only if GHL changes their API host/version)
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
GHL_USER_AGENT=BusinessImpactCanada/1.0

# Optional aliases for local tooling (server reads GHL_* first):
# VITE_GHL_PIT_TOKEN=
# VITE_GHL_LOCATION_ID=

# LEGACY (v1 EOL) — only used if GHL_PIT_TOKEN is unset; do not use in production
# GHL_API_KEY=
# VITE_GHL_API_KEY=
