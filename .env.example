NEXT_PUBLIC_SITE_URL=https://salesbreakdowninstitute.com

# Google Tag Manager (optional override; defaults to GTM-KQHFRMK8)
NEXT_PUBLIC_GTM_ID=GTM-KQHFRMK8

# Post–opt-in CTAs (public URLs; optional)
NEXT_PUBLIC_SHERPA_DEMO_URL=
NEXT_PUBLIC_WEBINAR_URL=
NEXT_PUBLIC_SHERPA_OFFER_URL=

# Firebase — client (safe to expose in the browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: App Check (not wired in Phase 2)
NEXT_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY=

# Firebase — server only (service account; never expose to the client)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ZenithMind ingestion (server-only; never expose to the client)
ZENITH_INGEST_SECRET=

# Zenith Content v1.2 HTTP ingestion (optional; falls back to ZENITH_INGEST_SECRET when unset)
ZENITH_CONTENT_SECRET=

# GoHighLevel — Private Integration only (NOT legacy Settings → Integrations → API key)
# Create: GHL → Settings → Other Settings → Private Integrations → Create New Integration
# Copy token once (pit-…). Minimum scopes: View Contacts, Edit Contacts, View Locations
# Server (Next.js API routes) — preferred:
GHL_PIT_TOKEN=
GHL_LOCATION_ID=
# Optional aliases (e.g. local tooling); server reads GHL_* first:
# VITE_GHL_PIT_TOKEN=
# VITE_GHL_LOCATION_ID=
# LeadConnector API base (default v2 — do not use rest.gohighlevel.com/v1)
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_USER_AGENT=SalesBreakdownInstitute/1.0
# LEGACY (v1 EOL) — only used if GHL_PIT_TOKEN is unset; migrate off GHL_API_KEY
# GHL_API_KEY=
